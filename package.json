{
  "name": "mapgen-monorepo",
  "version": "0.0.3-pre",
  "private": true,
  "description": "Material Map Generator - Pure Frontend Monorepo with Planet-Scale Simulation",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node node_modules/.bin/turbo run dev",
    "dev:server": "node node_modules/.bin/turbo run dev --filter=@mapgen/server",
    "dev:all": "node node_modules/.bin/turbo run dev --filter=@mapgen/web --filter=@mapgen/server",
    "build": "node node_modules/.bin/turbo run build",
    "build:server": "node node_modules/.bin/turbo run build --filter=@mapgen/server",
    "typecheck": "node node_modules/.bin/turbo run typecheck",
    "test": "node node_modules/.bin/turbo run test",
    "lint": "npx eslint packages/*/src --ext .ts,.tsx",
    "lint:fix": "npx eslint packages/*/src --ext .ts,.tsx --fix",
    "format": "npx prettier --write \"packages/*/src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "npx prettier --check \"packages/*/src/**/*.{ts,tsx,css,json,md}\""
  },
  "packageManager": "bun@1.2.14",
  "engines": {
    "bun": ">=1.2.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "playwright": "^1.61.1",
    "prettier": "^3.2.5",
    "puppeteer-core": "^25.2.1",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  }
}