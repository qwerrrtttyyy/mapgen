{
  "name": "@mapgen/manager",
  "version": "0.0.4-pre",
  "description": "Map Generator - CLI manager for installation, CRUD operations, and version management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mapgen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["map-generator", "manager", "cli", "version-control"],
  "author": "qwerrrtttyyy",
  "license": "MIT",
  "dependencies": {
    "@mapgen/core": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
