{
  "name": "@mapgen/shared-types",
  "version": "0.0.3-pre",
  "description": "Map Generator - Shared type contracts and serialization",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": ["map-generator", "types", "serialization"],
  "author": "qwerrrtttyyy",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@mapgen/core": "*",
    "msgpackr": "^1.10.0"
  }
}
